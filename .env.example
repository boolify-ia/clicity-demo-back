# Copia este archivo como .env.local para desarrollo local
# En Vercel, agrega estas variables desde el dashboard (Settings → Environment Variables)

# API key de Google AI Studio (gratis, sin tarjeta de crédito)
# Consíguela en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# API key de Anthropic (de pago, solo se usa como respaldo)
# Consíguela en: https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_anthropic_api_key_aqui
